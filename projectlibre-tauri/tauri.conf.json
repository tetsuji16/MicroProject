{
  "$schema": "https://tauri.studio/v1/config.schema.json",
  "package": {
    "productName": "MicroProject",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "distDir": "frontend",
    "devPath": "frontend/index.html",
    "withGlobalTauri": true
  },
  "tauri": {
    "allowlist": {
      "dialog": {
        "open": true,
        "save": true,
        "message": false,
        "ask": false,
        "confirm": false
      }
    },
    "windows": [
      {
        "title": "MicroProject",
        "width": 1280,
        "height": 840
      }
    ],
    "bundle": {
      "identifier": "com.tetsuji16.microproject",
      "active": true,
      "icon": ["icons/icon.ico"]
    }
  }
}
